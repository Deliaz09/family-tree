NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PHOTOS_BUCKET=photos

# Public URL used in emails and share links.
APP_PUBLIC_URL=https://family-tree.example.com

# Local development fallback for emails if APP_PUBLIC_URL is not set.
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173

# Frontend build-time API base.
# Use a public URL in production, or leave blank if the frontend and backend
# are served from the same origin and /api is proxied.
VITE_PUBLIC_API_URL=https://api.family-tree.example.com
VITE_API_URL=http://localhost:8000
VITE_API_PORT=8000
